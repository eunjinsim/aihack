          <span class="block text-xs font-bold text-vintage-dark truncate">${item.name}</span>
          <span class="text-[10px] font-mono text-vintage-clay">${item.prob}</span>
        `;
        targetGrid.appendChild(el);
      });

      // Safety comparison (allergens, dietary restriction, cross-contact,
      // spice level vs. the user's Taste Profile) — shared with the
