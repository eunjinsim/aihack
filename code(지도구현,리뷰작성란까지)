    // Generate accurate Korean text script for the TTS communicator.
    // When the person has a diet preference set (vegan/halal/vegetarian),
    // that's spoken first automatically. If diet is "none", only the
    // allergy information is announced, same as before.
    function getSpeechScript(dishNameText) {
      const targetDish = dishNameText || '이 요리';
      const allergyListKo = [];
      
      // Standard elements
      standardAllergens.forEach(allg => {
        if (state.selectedAllergies.has(allg.id)) {
          allergyListKo.push(allg.ko);
        }
      });

      // Custom elements (which are already translated to Korean)
      state.customAllergies.forEach(c => {
        allergyListKo.push(c.translated);
      });

      const dietPhrases = {
        vegan: '저는 비건이라 고기, 생선, 유제품, 계란, 꿀 등 모든 동물성 재료가 들어간 음식을 먹을 수 없습니다.',
        halal: '저는 할랄 음식만 먹을 수 있습니다. 돼지고기나 술이 들어간 음식은 피해야 합니다.',
        vegetarian: '저는 채식주의자라 고기와 생선이 들어간 음식을 먹지 않습니다.'
      };
      const dietPhrase = dietPhrases[state.dietary] || '';

      let allergyPhrase;
      if (allergyListKo.length === 0) {
        allergyPhrase = `${targetDish}에 어떠한 알레르기 유발 성분이 포함되어 있는지 확인해 주실 수 있나요?`;
      } else {
        const formattedAllergies = allergyListKo.join(', ');
        allergyPhrase = `저는 심한 [ ${formattedAllergies} ] 알레르기가 있습니다. ${targetDish}에 혹시 해당 성분이 들어가나요?`;
      }

      if (dietPhrase) {
        return `안녕하세요, ${dietPhrase} 그리고 ${allergyPhrase}`;
      }
      return `안녕하세요, ${allergyPhrase}`;
    }

