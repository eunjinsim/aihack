    // Handle standard camera / library file upload
    // Shrink a photo down to a reasonable max dimension + JPEG quality before
    // sending it anywhere. Phone camera photos are often 3-10MB, which is
    // well past Vercel's request size limit and causes 413 "Payload Too
    // Large" errors. Resized like this, most photos end up under ~300KB.
    function resizeImageForUpload(dataUrl, maxDimension, quality) {
      return new Promise((resolve, reject) => {
        const img = new Image();
        img.onload = () => {
          let { width, height } = img;
          if (width > maxDimension || height > maxDimension) {
            if (width >= height) {
              height = Math.round((height * maxDimension) / width);
              width = maxDimension;
            } else {
              width = Math.round((width * maxDimension) / height);
              height = maxDimension;
            }
          }
          const canvas = document.createElement('canvas');
          canvas.width = width;
          canvas.height = height;
          const ctx = canvas.getContext('2d');
          ctx.drawImage(img, 0, 0, width, height);
          resolve(canvas.toDataURL('image/jpeg', quality));
        };
        img.onerror = reject;
        img.src = dataUrl;
      });
    }

    function handleImageUpload(event) {
      const file = event.target.files[0];
      if (!file) return;

      const reader = new FileReader();
      reader.onload = async function(e) {
        try {
          // Shrink before showing/storing, so both the preview and the
          // upload to the AI endpoint use the same lightweight version.
          const resizedDataUrl = await resizeImageForUpload(e.target.result, 1024, 0.75);

          const previewImg = document.getElementById('scanned-image-preview');
          previewImg.src = resizedDataUrl;
          previewImg.classList.remove('hidden');
          document.getElementById('camera-blank').classList.add('hidden');
          document.getElementById('btn-trigger-scan').disabled = false;

          // A real user photo — scanning it will call the AI endpoint.
          state.isRealPhotoUpload = true;
          state.uploadedImageDataUrl = resizedDataUrl;
          document.getElementById('scan-loc-indicator').innerText = 'Custom Photo';
        } catch (err) {
          console.error('Image resize failed:', err);
          showToast(translations[state.lang].toastAiError);
        }
      };
      reader.readAsDataURL(file);
    }

    // Trigger laser effect, then route to either the real AI analysis
    // (for a photo the user actually took/uploaded) or the built-in demo
    // database (for a preloaded "Scan Menu Here" store photo).
    function triggerSimulatedScan() {
      const laser = document.getElementById('scan-laser');
      laser.classList.remove('hidden');
      
      // Animate laser bar
      let pos = 0;
      const interval = setInterval(() => {
        pos += 5;
        laser.style.top = `${pos}%`;
        if (pos >= 95) {
          clearInterval(interval);
          laser.classList.add('hidden');
          laser.style.top = '0%';

          if (state.isRealPhotoUpload && state.uploadedImageDataUrl) {
            analyzeMenuPhotoWithAI(state.uploadedImageDataUrl);
          } else {
            completeFoodScan();
          }
        }
      }, 50);

      showToast(translations[state.lang].toastScanning);
    }

    // Turn a dish name into a stable, url-safe key for the reviews database
    function slugifyFoodName(name) {
      return (name || 'dish')
        .toLowerCase()
        .replace(/[^a-z0-9]+/g, '')
        .slice(0, 40) || 'dish';
    }

    // Send the uploaded photo to our /api/analyze-menu serverless function
    // (which calls OpenAI's vision model server-side, keeping the API key
    // private) and render whatever it identifies using the same UI as the
    // built-in demo database.
    async function analyzeMenuPhotoWithAI(imageDataUrl) {
      try {
        const response = await fetch('/api/analyze-menu', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            imageBase64: imageDataUrl,
            targetLanguage: state.lang
          })
        });

        if (!response.ok) {
          const errBody = await response.json().catch(() => ({}));
          console.error('AI analysis failed:', response.status, errBody);
          showToast(translations[state.lang].toastAiError);
          return;
        }

        const aiData = await response.json();
        const rawDishes = Array.isArray(aiData.dishes) ? aiData.dishes : [];

        if (rawDishes.length === 0) {
          showToast(translations[state.lang].toastAiError);
          return;
        }

        const dishes = rawDishes.map(d => ({
          foodId: slugifyFoodName(d.name_en || d.name_ko),
          name: d.name_ko && (d.translated_name || d.name_en)
            ? `${d.translated_name || d.name_en} (${d.name_ko})`
            : (d.translated_name || d.name_en || d.name_ko || 'Unknown dish'),
          nameKo: d.name_ko || d.name_en || 'Unknown dish',
          ingredients: d.ingredients || '',
          allergens: Array.isArray(d.allergens) ? d.allergens : [],
          crossContactAllergens: Array.isArray(d.crossContactAllergens) ? d.crossContactAllergens : [],
          spicy: Number.isFinite(d.spicy) ? Math.max(0, Math.min(3, Math.round(d.spicy))) : 0,
          eatingMethod: Array.isArray(d.eatingMethod) ? d.eatingMethod : [],
          description: d.description || '',
          culturalNote: d.culturalNote || ''
        }));

        state.hasScannedResult = true;
        renderMultiDishScanResult(dishes);
      } catch (err) {
        console.error('analyzeMenuPhotoWithAI error:', err);
        showToast(translations[state.lang].toastAiError);
      }
    }

    // Check a single dish's allergens/cross-contact/spice against the
    // user's profile. Returns 'red' | 'orange' | 'green' plus which
    // allergen ids matched (for display).
    // Which of the 19 standard allergen ids are animal-derived ingredients
    // that violate a given dietary restriction. Reuses the same `allergens`
    // array Gemini already returns for every dish (real scans included), so
    // no new AI schema field is needed to check dietary compatibility.
    const DIETARY_VIOLATION_ALLERGENS = {
      vegan: ['pork', 'beef', 'chicken', 'egg', 'milk', 'shrimp', 'crab', 'squid', 'mackerel', 'shellfish'],
      vegetarian: ['pork', 'beef', 'chicken', 'shrimp', 'crab', 'squid', 'mackerel', 'shellfish'],
      halal: ['pork']
    };

    function violatesDietary(dish, dietary) {
      if (!dietary || dietary === 'none') return false;
      const violatingIds = DIETARY_VIOLATION_ALLERGENS[dietary] || [];
      return (dish.allergens || []).some(allg => violatingIds.includes(allg));
    }

    function checkDishSafety(dish) {
      let safetyState = 'green';
      let isCrossContact = false;
      const matchedDangers = [];

      (dish.allergens || []).forEach(allg => {
        const standardItem = standardAllergens.find(x => x.id === allg);
        if (standardItem && (state.selectedAllergies.has(allg) || state.customAllergies.some(x => x.translated === standardItem.ko))) {
          safetyState = 'red';
          matchedDangers.push(allg);
        }
      });

      // A dish that conflicts with the user's own dietary restriction
      // (vegan/vegetarian/halal) is treated as seriously as an allergen
      // match — both are hard "do not eat" constraints, not preferences.
      if (safetyState !== 'red' && violatesDietary(dish, state.dietary)) {
        safetyState = 'red';
        matchedDangers.push(state.dietary);
      }

      if (safetyState !== 'red' && dish.crossContactAllergens) {
        dish.crossContactAllergens.forEach(allg => {
          const standardItem = standardAllergens.find(x => x.id === allg);
          if (standardItem && (state.selectedAllergies.has(allg) || state.customAllergies.some(x => x.translated === standardItem.ko))) {
            safetyState = 'orange';
            isCrossContact = true;
            matchedDangers.push(allg);
          }
        });
      }

      if (safetyState === 'green' && dish.spicy > state.selectedSpicy) {
        safetyState = 'orange';
      }

      return { safetyState, isCrossContact, matchedDangers };
    }

    // Render a list of multiple dishes detected in one photo (real AI scan
    // of a menu board). Shows one overall safety banner (worst case across
    // all dishes) plus every dish's name, ingredients, spice level, and its
    // own individual safety indicator.
    function renderMultiDishScanResult(dishes) {
      const trans = translations[state.lang];
      const severityRank = { green: 0, orange: 1, red: 2 };
      let overall = { safetyState: 'green', isCrossContact: false, matchedDangers: [] };
      const perDish = dishes.map(dish => {
        const result = checkDishSafety(dish);
        if (severityRank[result.safetyState] > severityRank[overall.safetyState]) {
          overall = result;
        }
        return { dish, result };
      });

      // For the "Ask Waiter" TTS question, prefer naming just the dishes
      // that actually flagged a risk — falls back to all dishes if none did.
      const riskyNames = perDish.filter(p => p.result.safetyState !== 'green').map(p => p.dish.nameKo);
      state.lastScannedDishNamesKo = riskyNames.length > 0 ? riskyNames : dishes.map(d => d.nameKo);

      // Render vision target items (Korean names as a quick glance grid)
      const targetGrid = document.getElementById('vision-elements-list');
      targetGrid.innerHTML = '';
      dishes.slice(0, 9).forEach(dish => {
        const el = document.createElement('div');
        el.className = "bg-vintage-beige/50 p-2 rounded-lg text-center border border-vintage-dark/5";
        el.innerHTML = `<span class="block text-xs font-bold text-vintage-dark truncate">${dish.name}</span>`;
        targetGrid.appendChild(el);
      });

      // Overall banner (worst-case across all dishes)
      const banner = document.getElementById('profile-match-banner');
      const bannerTitle = document.getElementById('match-status-title');
      const bannerDesc = document.getElementById('match-status-desc');
      const bannerIcon = document.getElementById('match-status-icon');

      if (overall.safetyState === 'green') {
        banner.className = "p-3 rounded-xl bg-emerald-50 text-emerald-900 border border-emerald-200";
        bannerTitle.innerText = trans.safeTitle;
        bannerDesc.innerText = trans.safeDesc;
        bannerIcon.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>`;
      } else if (overall.safetyState === 'orange') {
        banner.className = "p-3 rounded-xl bg-amber-50 text-amber-900 border border-amber-200";
        bannerTitle.innerText = trans.warnTitle;
        bannerDesc.innerText = overall.isCrossContact ? `${trans.crossDesc} (${overall.matchedDangers.join(', ').toUpperCase()})` : trans.warnDesc;
        bannerIcon.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>`;
      } else {
        banner.className = "p-3 rounded-xl bg-red-50 text-red-900 border border-red-200";
        bannerTitle.innerText = trans.dangerTitle;
        bannerDesc.innerText = `${trans.dangerDesc} (Matched: ${overall.matchedDangers.join(', ').toUpperCase()})`;
        bannerIcon.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>`;
      }

      // Render every dish as a card: name, spice level, how-to-eat steps,
      // and a short description. Individual per-dish safety dots, ingredient
      // text, and dietary flags were removed — the one overall banner above
      // already covers safety at a glance.
      const listContainer = document.getElementById('multi-dish-list');
      listContainer.innerHTML = '';
      const spicyTextMap = ['Mild', 'Normal', 'Hot 🔥', 'Extreme 🌶️'];
      const howToEatLabel = translations[state.lang].howToEatLabel || 'How to Eat';

      perDish.forEach(({ dish }) => {
        const card = document.createElement('div');
        card.className = "bg-vintage-beige/30 p-3 rounded-xl space-y-2";
        const stepsHtml = (dish.eatingMethod || []).map((step, idx) => `
          <div class="flex gap-1.5 items-start">
            <span class="w-4 h-4 shrink-0 rounded-full bg-vintage-clay/20 text-vintage-terracotta text-[9px] font-bold flex items-center justify-center mt-0.5">${idx + 1}</span>
            <p class="text-[11px] text-vintage-dark leading-relaxed">${step}</p>
          </div>
        `).join('');
        card.innerHTML = `
          <div class="flex items-center justify-between gap-2">
            <span class="font-semibold text-sm text-vintage-dark">${dish.name}</span>
            <span class="text-[10px] font-mono text-vintage-clay shrink-0">${spicyTextMap[dish.spicy]}</span>
          </div>
          ${dish.description ? `<p class="text-[11px] text-vintage-olive leading-relaxed">${dish.description}</p>` : ''}
          ${stepsHtml ? `<div class="space-y-1 pt-1 border-t border-vintage-dark/10">
            <span class="text-[9px] font-bold text-vintage-olive uppercase">${howToEatLabel}</span>
            ${stepsHtml}
          </div>` : ''}
          ${dish.culturalNote ? `<div class="p-2 bg-vintage-sage/10 text-vintage-olive rounded-lg text-[10px] flex gap-1.5 border border-vintage-sage/20">
            <span class="shrink-0">💡</span><span>${dish.culturalNote}</span>
          </div>` : ''}
        `;
        listContainer.appendChild(card);
      });

      // Show the multi-dish list, hide the single-dish detail view
      document.getElementById('single-dish-details').classList.add('hidden');
      listContainer.classList.remove('hidden');

      // Multiple different dishes were found — reviews don't map cleanly to
      // any single one, so clear the review-linking state for this scan.
      state.currentReviewFoodId = null;

      document.getElementById('scan-result-pane').classList.remove('hidden');
      showToast(translations[state.lang].toastScanDone);
    }

    // Food Scanner completed math output
    function completeFoodScan() {
      const activeLoc = locations[state.currentLocIdx];
      renderScanResultUI(activeLoc.matchedFoodObj);
    }

    // Shared UI renderer: takes a matchObj shape (foodId, name, ingredients,
    // allergens, crossContactAllergens, dietaryFlags, spicy, elements,
    // eatingMethod, culturalNote) from the built-in demo database (used by
    // the "Scan Menu Here" flow tied to a known map location), and paints
    // the single-dish result pane.
