    // Falls back to a country derived from the UI language whenever the user
    // hasn't typed their own nationality into the profile.
    const LANG_TO_COUNTRY = { en: 'USA', ja: 'Japan', zh: 'China', vi: 'Vietnam', es: 'Spain', ko: 'Korea' };

    function getUserCountry() {
      const custom = (state.nationality || '').trim();
      return custom || LANG_TO_COUNTRY[state.lang] || 'Traveler';
    }

    // Minimum reviews required before a tier is considered statistically
    // meaningful enough to show instead of falling back to a broader group.
    const SIMILAR_MIN_SAMPLE = 3;

    // Cascades from the most specific match (country + spice tolerance +
    // dietary) down to "all reviews" whenever a tier doesn't have enough
    // data, per the filtering priority: country+spice+dietary -> country+spice
    // -> country -> all.
    function findSimilarTravelerReviews(reviews, country, spiceTolerance, dietary) {
      const byCountrySpiceDiet = reviews.filter(r => r.country === country && r.spiceTolerance === spiceTolerance && r.dietary === dietary);
      if (byCountrySpiceDiet.length >= SIMILAR_MIN_SAMPLE) {
        return { reviews: byCountrySpiceDiet, tier: 'country+spice+dietary' };
      }
      const byCountrySpice = reviews.filter(r => r.country === country && r.spiceTolerance === spiceTolerance);
      if (byCountrySpice.length >= SIMILAR_MIN_SAMPLE) {
        return { reviews: byCountrySpice, tier: 'country+spice' };
      }
      const byCountry = reviews.filter(r => r.country === country);
      if (byCountry.length >= SIMILAR_MIN_SAMPLE) {
        return { reviews: byCountry, tier: 'country' };
      }
      return { reviews: reviews, tier: 'all' };
    }

    // ==========================================
    // PROFILE PERSISTENCE (survives page refresh)
    // ==========================================
    const PROFILE_STORAGE_KEY = 'fitbridge_profile_v1';

    function saveProfileToStorage() {
      try {
        const profileData = {
          lang: state.lang,
          dietary: state.dietary,
          nationality: state.nationality,
          selectedSpicy: state.selectedSpicy,
          selectedAllergies: Array.from(state.selectedAllergies),
          customAllergies: state.customAllergies,
          onboardingComplete: true
        };
        localStorage.setItem(PROFILE_STORAGE_KEY, JSON.stringify(profileData));
      } catch (err) {
        // localStorage may be unavailable (e.g. private browsing, or an
        // in-app preview sandbox). Fail silently — the app still works,
        // it just won't remember settings after a refresh in that case.
        console.error('Could not save profile to local storage:', err);
      }
    }

    function loadProfileFromStorage() {
      try {
        const raw = localStorage.getItem(PROFILE_STORAGE_KEY);
        return raw ? JSON.parse(raw) : null;
      } catch (err) {
        console.error('Could not load profile from local storage:', err);
        return null;
      }
    }

    window.onload = function() {
      // Each step is isolated so that a failure in one (e.g. map or exchange
      // rate API being blocked/offline) never prevents the rest of the app
      // from initializing correctly.
      const safeRun = (fn, label) => {
        try {
          fn();
        } catch (err) {
          console.error(`Init step "${label}" failed:`, err);
        }
      };

      // Try to restore a previously saved profile so returning users skip
      // onboarding entirely and land straight in the main app.
      const savedProfile = loadProfileFromStorage();
      const hasSavedProfile = !!(savedProfile && savedProfile.onboardingComplete);

      if (hasSavedProfile) {
        state.dietary = savedProfile.dietary || 'none';
        state.nationality = savedProfile.nationality || '';
        state.selectedSpicy = typeof savedProfile.selectedSpicy === 'number' ? savedProfile.selectedSpicy : 1;
        state.selectedAllergies = new Set(savedProfile.selectedAllergies || []);
        state.customAllergies = savedProfile.customAllergies || [];

        document.getElementById('landing-page').classList.add('hidden');
        document.getElementById('main-app').classList.remove('hidden');
      }

      const initialLang = hasSavedProfile ? (savedProfile.lang || 'en') : 'en';
      const initialSpicy = hasSavedProfile ? state.selectedSpicy : 1;

      safeRun(fetchLiveExchangeRates, 'fetchLiveExchangeRates');
      safeRun(renderAllergiesGrid, 'renderAllergiesGrid');
      safeRun(() => setLanguage(initialLang), 'setLanguage');
      safeRun(() => setSpicy(initialSpicy), 'setSpicy');
      safeRun(() => {
        // Reflect restored diet choice in both select dropdowns
        const dietSelect = document.getElementById('diet-select');
        const modalDietSelect = document.getElementById('modal-diet-select');
        if (dietSelect) dietSelect.value = state.dietary;
        if (modalDietSelect) modalDietSelect.value = state.dietary;
      }, 'restoreDietSelects');
      safeRun(() => {
        // Reflect restored nationality in both text inputs
        const nationalityInput = document.getElementById('nationality-input');
        const modalNationalityInput = document.getElementById('modal-nationality-input');
        if (nationalityInput) nationalityInput.value = state.nationality;
        if (modalNationalityInput) modalNationalityInput.value = state.nationality;
      }, 'restoreNationalityInputs');
      // Map starts with only markers visible — no location is auto-selected,
      // so the detail card + reviews stay hidden until the user actually
      // taps a marker (selectLocation reveals them).
      safeRun(initLeafletMap, 'initLeafletMap');

      if (hasSavedProfile) {
        safeRun(() => showToast(translations[state.lang].toastWelcomeBack || 'Welcome back!'), 'welcomeBackToast');
      }
    };

    // Show Toast Custom Notification
    function showToast(message) {
      const toast = document.getElementById('toast');
      const toastMsg = document.getElementById('toast-message');
      toastMsg.innerText = message;
      toast.classList.remove('hidden');
      setTimeout(() => {
        toast.classList.add('hidden');
      }, 2500);
    }

    // Tab Switching
    function switchTab(tabName) {
      state.activeTab = tabName;
      document.querySelectorAll('.tab-content').forEach(el => el.classList.add('hidden'));
      document.getElementById(`view-${tabName}`).classList.remove('hidden');

      // Update active navigation state
      document.querySelectorAll('nav button').forEach(btn => {
        btn.classList.remove('text-vintage-clay');
        btn.classList.add('text-vintage-olive');
      });
      document.getElementById(`nav-${tabName}`).classList.add('text-vintage-clay');
      document.getElementById(`nav-${tabName}`).classList.remove('text-vintage-olive');

      // Leaflet caches the container size at creation time, so a map that
      // was initialized while its tab was hidden needs an explicit nudge
      // once it's actually visible again.
      if (tabName === 'map' && mapInstance) {
        setTimeout(() => mapInstance.invalidateSize(), 100);
      }
    }

    // Toggle Landing / Onboarding Screen to Main View
    function completeOnboarding() {
      document.getElementById('landing-page').classList.add('hidden');
      document.getElementById('main-app').classList.remove('hidden');
      showToast("FitBridge Activated! Safe travel initialized.");
      updateTtsDraft();
      saveProfileToStorage();
      if (mapInstance) {
        setTimeout(() => mapInstance.invalidateSize(), 200);
      }
    }

    // Set Active UI Language and translate both hardcoded labels + input fields
    function setLanguage(langCode) {
      state.lang = langCode;

      // Highlight language select in landing
      document.querySelectorAll('.lang-selector').forEach(btn => {
        btn.classList.remove('bg-vintage-terracotta', 'text-white', 'border-vintage-terracotta');
        btn.classList.add('bg-white', 'text-vintage-dark', 'border-vintage-dark/10');
      });
      const selectedBtn = document.getElementById(`lang-btn-${langCode}`);
      if (selectedBtn) {
        selectedBtn.classList.remove('bg-white', 'text-vintage-dark');
        selectedBtn.classList.add('bg-vintage-terracotta', 'text-white', 'border-vintage-terracotta');
      }

      // Highlight language in modal as well
      document.querySelectorAll('.modal-lang-selector').forEach(btn => {
        btn.classList.remove('bg-vintage-terracotta', 'text-white');
        btn.classList.add('bg-white', 'text-vintage-dark');
      });
      const modalBtn = document.getElementById(`modal-lang-${langCode}`);
      if (modalBtn) {
        modalBtn.classList.remove('bg-white', 'text-vintage-dark');
        modalBtn.classList.add('bg-vintage-terracotta', 'text-white');
      }

      // Perform translation
      translateUI();
      renderAllergiesGrid(); 
      renderCustomAllergyBadges();
      updateMapMarkers(); // marker popups show localized name/dish, so re-render for the new language
      if (state.selectedLocation) {
        selectLocation(state.selectedLocation.id);
      }
      updateTtsDraft();

      // Persist immediately, but only once the user is actually inside the
      // app — the very first setLanguage('en') call on a fresh visit runs
      // while main-app is still hidden (onboarding not completed yet), and
      // must NOT mark onboardingComplete in localStorage prematurely.
      if (!document.getElementById('main-app').classList.contains('hidden')) {
        saveProfileToStorage();
      }

      // A real AI menu-scan result is currently on screen — re-run the same
      // analysis so its menu name/description/ingredients/eating method
      // switch to the newly selected language instead of staying stale.
      if (state.hasScannedResult && state.isRealPhotoUpload && state.uploadedImageDataUrl) {
        analyzeMenuPhotoWithAI(state.uploadedImageDataUrl);
      }
    }

    function translateUI() {
      const trans = translations[state.lang];

      // Landing
      document.getElementById('landing-tagline').innerText = trans.tagline;
      document.getElementById('landing-footer').innerText = trans.footerTagline;
      document.getElementById('lbl-quick-profile').innerText = trans.quickProfile;
      document.getElementById('lbl-diet').innerText = trans.diet;
      document.getElementById('lbl-nationality').innerText = trans.nationalityLabel;
      document.getElementById('nationality-input').placeholder = trans.nationalityPlaceholder;
      document.getElementById('lbl-spicy').innerText = trans.spicy;
      document.getElementById('btn-enter-text').innerText = trans.beginBtn;

      // Localize Select options dynamically
      const dietSelect = document.getElementById('diet-select');
      const modalDietSelect = document.getElementById('modal-diet-select');
      
      const currentDietValue = dietSelect.value || 'none';

      const dietOptionsHTML = `
        <option value="none">${trans.dietNone}</option>
        <option value="vegan">${trans.dietVegan}</option>
        <option value="halal">${trans.dietHalal}</option>
        <option value="vegetarian">${trans.dietVegetarian}</option>
      `;
      dietSelect.innerHTML = dietOptionsHTML;
      modalDietSelect.innerHTML = dietOptionsHTML;
      
      dietSelect.value = currentDietValue;
