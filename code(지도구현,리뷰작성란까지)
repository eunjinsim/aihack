<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>FitBridge - 전포 트래블 키트 (Jeonpo Travel Kit)</title>
  
  <!-- Tailwind CSS -->
  <script src="https://cdn.tailwindcss.com"></script>
  <!-- Google Fonts for Vintage Elegance -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Lora:ital,wght@0,400..700;1,400..700&family=Noto+Sans+KR:wght@300;400;500;700&display=swap" rel="stylesheet">

  <!-- Leaflet + OpenStreetMap: free, no API key required. -->
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" integrity="sha256-p4NxAoJBhIIN+hmNHrzRCf9tD/miZyoHS5obTRR9BMY=" crossorigin="" />
  <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js" integrity="sha256-20nQCchB9co0qIjJZRGuk2/Z9VM+kNiyxNV1lvTlZBo=" crossorigin=""></script>

  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: {
            serif: ['Playfair Display', 'Lora', 'Georgia', 'serif'],
            sans: ['Noto Sans KR', 'sans-serif'],
          },
          colors: {
            vintage: {
              cream: '#FAF6F0',
              beige: '#F1ECE4',
              clay: '#C97A53',
              terracotta: '#A65B32',
              dark: '#2E2520',
              sage: '#8FA89B',
              olive: '#5F6F65'
            }
          }
        }
      }
    }
  </script>
  
  <style>
    /* Smooth vintage scrollbars */
    ::-webkit-scrollbar {
      width: 6px;
    }
    ::-webkit-scrollbar-track {
      background: #F1ECE4;
    }
    ::-webkit-scrollbar-thumb {
      background: #C97A53;
      border-radius: 3px;
    }
    .vintage-border {
      border: 1px solid rgba(46, 37, 32, 0.12);
    }
    .vintage-shadow {
      box-shadow: 0 4px 20px -2px rgba(46, 37, 32, 0.08);
    }
    .vintage-glow {
      animation: warm-pulse 2s infinite ease-in-out;
    }
    @keyframes warm-pulse {
      0%, 100% { box-shadow: 0 0 0 0px rgba(201, 122, 83, 0.4); }
      50% { box-shadow: 0 0 0 8px rgba(201, 122, 83, 0); }
    }
    /* Vintage-style tweaks for the Leaflet map container */
    #jeonpo-map {
      font-family: 'Noto Sans KR', sans-serif;
    }
    #jeonpo-map .leaflet-pane,
    #jeonpo-map .leaflet-control {
      z-index: 5; /* stay below modals/header, which use higher z-index values */
    }
  </style>
</head>
<body class="bg-vintage-cream text-vintage-dark font-sans selection:bg-vintage-clay selection:text-white min-h-screen flex justify-center">

  <!-- Mobile-centric desktop wrapper to mimic authentic travel application -->
  <div class="w-full max-w-md bg-vintage-cream min-h-screen flex flex-col relative shadow-2xl border-x border-vintage-dark/10 overflow-x-hidden">
    
    <!-- Toast Notification Container -->
    <div id="toast" class="fixed top-4 left-1/2 transform -translate-x-1/2 z-50 bg-vintage-dark text-vintage-cream px-4 py-3 rounded-lg text-sm font-medium vintage-shadow hidden flex items-center gap-2 max-w-[90%] border border-vintage-clay/20">
      <span id="toast-message">Notification message</span>
    </div>

    <!-- ==========================================
         STAGE 1: LANDING & INITIALIZATION (FitBridge)
         ========================================== -->
    <div id="landing-page" class="flex-1 flex flex-col justify-between p-6 z-10 bg-vintage-cream">
      
      <!-- Top Vintage Brand Banner -->
      <div class="text-center pt-8">
        <span class="text-xs uppercase tracking-[0.2em] text-vintage-olive font-semibold">Welcome to Busan</span>
        <h1 class="font-serif text-5xl font-bold text-vintage-terracotta mt-2 tracking-wide">FitBridge</h1>
        <p class="font-serif italic text-vintage-olive text-sm mt-1" id="landing-tagline">Your Local Jeonpo Travel Companion</p>
        <div class="w-16 h-[2px] bg-vintage-clay mx-auto mt-6"></div>
      </div>

      <!-- Main Step Onboarding Card -->
      <div class="bg-vintage-beige/60 rounded-2xl p-5 vintage-border vintage-shadow my-6 space-y-6">
        
        <!-- Language Choice -->
        <div>
          <label class="block text-xs uppercase tracking-wider text-vintage-olive font-bold mb-2">Select Your Language / 国籍・言語</label>
          <div class="grid grid-cols-3 gap-2">
            <button onclick="setLanguage('en')" id="lang-btn-en" class="lang-selector py-2 px-2 text-xs rounded-lg font-medium vintage-border bg-white hover:bg-vintage-beige transition flex flex-col items-center gap-0.5">
              <span>🇺🇸 English</span> <span class="text-[10px] text-vintage-olive">EN</span>
            </button>
            <button onclick="setLanguage('ja')" id="lang-btn-ja" class="lang-selector py-2 px-2 text-xs rounded-lg font-medium vintage-border bg-white hover:bg-vintage-beige transition flex flex-col items-center gap-0.5">
              <span>🇯🇵 日本語</span> <span class="text-[10px] text-vintage-olive">JA</span>
            </button>
            <button onclick="setLanguage('zh')" id="lang-btn-zh" class="lang-selector py-2 px-2 text-xs rounded-lg font-medium vintage-border bg-white hover:bg-vintage-beige transition flex flex-col items-center gap-0.5">
              <span>🇨🇳 简体中文</span> <span class="text-[10px] text-vintage-olive">ZH</span>
            </button>
            <button onclick="setLanguage('vi')" id="lang-btn-vi" class="lang-selector py-2 px-2 text-xs rounded-lg font-medium vintage-border bg-white hover:bg-vintage-beige transition flex flex-col items-center gap-0.5">
              <span>🇻🇳 Tiếng Việt</span> <span class="text-[10px] text-vintage-olive">VI</span>
            </button>
            <button onclick="setLanguage('es')" id="lang-btn-es" class="lang-selector py-2 px-2 text-xs rounded-lg font-medium vintage-border bg-white hover:bg-vintage-beige transition flex flex-col items-center gap-0.5">
              <span>🇪🇸 Español</span> <span class="text-[10px] text-vintage-olive">ES</span>
            </button>
            <button onclick="setLanguage('ko')" id="lang-btn-ko" class="lang-selector py-2 px-2 text-xs rounded-lg font-medium vintage-border bg-white hover:bg-vintage-beige transition flex flex-col items-center gap-0.5">
              <span>🇰🇷 한국어</span> <span class="text-[10px] text-vintage-olive">KO</span>
            </button>
          </div>
        </div>

        <div class="h-[1px] bg-vintage-dark/10"></div>

        <!-- Quick Preferences -->
        <div class="space-y-4">
          <h3 class="font-serif text-lg font-semibold text-vintage-dark text-center" id="lbl-quick-profile">Quick Safety Profile</h3>
          
          <!-- Diet Selection -->
          <div>
            <label class="block text-xs font-semibold text-vintage-olive mb-1" id="lbl-diet">Dietary Restrictions</label>
            <select id="diet-select" onchange="syncOnboardingDiet()" class="w-full text-xs p-2.5 rounded-lg bg-white vintage-border text-vintage-dark focus:outline-none focus:ring-1 focus:ring-vintage-clay">
              <!-- Dynamically localized via JS -->
            </select>
          </div>

          <!-- Nationality / Country (used to find similar traveler reviews) -->
          <div>
            <label class="block text-xs font-semibold text-vintage-olive mb-1" id="lbl-nationality">Your Country / Nationality</label>
            <input type="text" id="nationality-input" oninput="syncOnboardingNationality()" placeholder="e.g. USA, Japan, Spain" class="w-full text-xs p-2.5 rounded-lg bg-white vintage-border text-vintage-dark focus:outline-none focus:ring-1 focus:ring-vintage-clay">
          </div>

          <!-- Spicy Level Selector -->
          <div>
            <label class="block text-xs font-semibold text-vintage-olive mb-1" id="lbl-spicy">Spicy Preference</label>
            <div class="grid grid-cols-4 gap-1 text-center">
              <button onclick="setSpicy(0)" id="spicy-btn-0" class="spicy-selector p-2 text-xs rounded bg-white vintage-border hover:bg-vintage-beige transition">Mild</button>
              <button onclick="setSpicy(1)" id="spicy-btn-1" class="spicy-selector p-2 text-xs rounded bg-white vintage-border hover:bg-vintage-beige transition">Normal</button>
              <button onclick="setSpicy(2)" id="spicy-btn-2" class="spicy-selector p-2 text-xs rounded bg-white vintage-border hover:bg-vintage-beige transition">Hot 🔥</button>
              <button onclick="setSpicy(3)" id="spicy-btn-3" class="spicy-selector p-2 text-xs rounded bg-white vintage-border hover:bg-vintage-beige transition">Extreme 🌶️</button>
            </div>
            <div class="mt-2 p-2.5 bg-vintage-sage/10 border border-vintage-sage/20 rounded-lg text-[11px] text-vintage-olive leading-relaxed flex gap-1.5" id="spicy-desc-box">
              <span class="shrink-0">💡</span>
              <span id="spicy-desc-text">Most first-time visitors choose this level.</span>
            </div>
          </div>
        </div>

      </div>

      <!-- Enter App CTA -->
      <div class="pb-6">
        <button onclick="completeOnboarding()" class="w-full py-4 bg-vintage-terracotta text-white rounded-xl font-serif text-lg font-bold hover:bg-vintage-dark transition duration-300 vintage-shadow vintage-glow flex justify-center items-center gap-2">
          <span id="btn-enter-text">Begin Safe Journey</span>
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3" /></svg>
        </button>
        <p class="text-[10px] text-vintage-olive text-center mt-3 italic" id="landing-footer">Jeonpo Cafe Street Safety Navigation & Companion By FitBridge</p>
      </div>

    </div>

    <!-- ==========================================
         STAGE 2: MAIN WEB APP WORKSPACE
         ========================================== -->
    <div id="main-app" class="hidden flex-1 flex flex-col justify-between">
      
      <!-- Vintage App Header -->
      <header class="bg-white border-b border-vintage-dark/10 py-3 px-4 flex justify-between items-center z-20 vintage-shadow">
        <div class="flex items-center gap-2">
          <span class="font-serif font-extrabold text-xl text-vintage-terracotta tracking-wider">FitBridge</span>
          <span class="text-[10px] px-2 py-0.5 rounded-full bg-vintage-sage/20 text-vintage-olive font-semibold uppercase tracking-widest">Jeonpo</span>
        </div>
        <div class="flex items-center gap-1.5">
          <!-- Reset to initial onboarding screen (clears saved profile) -->
          <button onclick="resetToOnboarding()" class="p-2 rounded-full bg-vintage-beige/60 hover:bg-vintage-beige transition" title="Reset / Start Over">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-vintage-dark" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 1121.21 19.623M20 11H15V6" /></svg>
          </button>
          <button onclick="openProfileModal()" class="p-2 rounded-full bg-vintage-beige/60 hover:bg-vintage-beige transition relative group">
            <!-- Profile indicator count of active allergies -->
            <span id="allergy-badge" class="absolute -top-1 -right-1 bg-vintage-clay text-white text-[9px] w-4 h-4 rounded-full flex items-center justify-center font-bold hidden">0</span>
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-vintage-dark" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
          </button>
        </div>
      </header>

      <!-- Main Dynamic Content Container -->
      <main class="flex-1 overflow-y-auto pb-24 relative">

        <!-- ==================== TAB 1: INTERACTIVE GOOGLE MAP ==================== -->
        <section id="view-map" class="tab-content p-4 space-y-4">
          <div class="flex justify-between items-center">
            <div>
              <h2 class="font-serif text-2xl font-bold text-vintage-dark" id="map-title">Jeonpo Safe Map</h2>
              <p class="text-xs text-vintage-olive" id="map-subtitle">Tap markers to discover menus & safety parameters</p>
            </div>
            <span class="text-[11px] bg-vintage-sage/10 text-vintage-olive px-2.5 py-1 rounded-full border border-vintage-sage/20 font-medium">Busan, S. Korea</span>
          </div>

          <!-- Real Interactive Map Filters -->
          <div class="flex gap-2 p-1 bg-vintage-beige/50 rounded-xl vintage-border">
            <button onclick="setMapFilter('all')" id="filter-all" class="map-filter-btn flex-1 py-1.5 text-xs font-semibold rounded-lg transition bg-white text-vintage-dark shadow-sm">All</button>
            <button onclick="setMapFilter('restaurant')" id="filter-restaurant" class="map-filter-btn flex-1 py-1.5 text-xs font-semibold rounded-lg transition text-vintage-olive hover:bg-white/50">🍚 Restaurants</button>
            <button onclick="setMapFilter('cafe')" id="filter-cafe" class="map-filter-btn flex-1 py-1.5 text-xs font-semibold rounded-lg transition text-vintage-olive hover:bg-white/50">☕ Cafes</button>
          </div>

          <!-- Leaflet / OpenStreetMap Container -->
          <div class="relative w-full h-72 rounded-2xl overflow-hidden vintage-border shadow-inner">
            <div id="jeonpo-map" class="w-full h-full"></div>
          </div>

          <!-- Selected Location Detail Card — hidden until a marker is tapped -->
          <div id="location-detail-card" class="hidden bg-white p-4 rounded-xl vintage-border vintage-shadow border-l-4 border-vintage-clay transition-all duration-300 transform scale-100">
            <div class="flex justify-between items-start">
              <div>
                <span class="text-[10px] uppercase font-bold text-vintage-clay tracking-wider" id="loc-cat">KOREAN RESTAURANT</span>
                <h3 class="font-serif text-xl font-bold text-vintage-dark mt-0.5" id="loc-name">Jeonpo Solgup Samgyeopsal</h3>
              </div>
              <div class="flex items-center gap-1 bg-amber-50 text-amber-700 px-2 py-0.5 rounded text-xs font-bold">
                ⭐ <span id="loc-rating">4.8</span>
              </div>
            </div>
            
            <p class="text-xs text-vintage-olive mt-2 leading-relaxed" id="loc-desc">Traditional Korean Pork belly grilled on a iron cauldron lid with ripe Kimchi.</p>
            
            <div class="mt-3 grid grid-cols-2 gap-2 text-xs">
              <div class="bg-vintage-beige/40 p-2 rounded">
                <span class="block text-[10px] text-vintage-olive font-bold uppercase" id="loc-lbl-dish">Main Speciality</span>
                <span class="font-medium text-vintage-dark" id="loc-dishes">Samgyeopsal Set</span>
              </div>
              <div class="bg-vintage-beige/40 p-2 rounded">
                <span class="block text-[10px] text-vintage-olive font-bold uppercase" id="loc-lbl-allergy">Triggers in House</span>
                <span class="font-medium text-vintage-terracotta" id="loc-allergens">Pork, Garlic, Soy</span>
              </div>
            </div>

            <div class="mt-4 flex gap-2">
              <button onclick="startScanningPreload()" class="flex-1 py-2.5 bg-vintage-dark text-white rounded-lg text-xs font-semibold hover:bg-vintage-terracotta transition flex items-center justify-center gap-1.5">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
                <span id="btn-scan-loc-menu">Scan Menu Here</span>
              </button>
            </div>
          </div>

          <!-- Selected Location's Traveler Reviews — hidden until a marker is
               tapped, shown automatically (no extra click) right below the
               detail card above. -->
          <div id="map-reviews-section" class="hidden bg-white p-4 rounded-xl vintage-border vintage-shadow space-y-4">
            <div class="flex items-center gap-2">
              <span class="text-xl">⭐</span>
              <h3 class="font-serif text-lg font-bold text-vintage-dark" id="map-reviews-title">Traveler Reviews</h3>
            </div>
            <p class="text-xs text-vintage-olive -mt-3" id="map-reviews-food-name">Samgyeopsal</p>

            <!-- Similar Traveler Stat Card -->
            <div class="bg-vintage-beige/40 p-3.5 rounded-xl grid grid-cols-2 gap-2.5 text-center" id="reviews-similar-stats">
              <div class="bg-white p-2.5 rounded-lg vintage-border">
                <span class="text-base font-serif font-bold text-vintage-terracotta" id="reviews-country-strong-pct">—</span>
                <span class="text-[9px] text-vintage-olive block leading-tight mt-0.5" id="reviews-country-strong-label">of travelers rated Strong+</span>
              </div>
              <div class="bg-white p-2.5 rounded-lg vintage-border">
                <span class="text-base font-serif font-bold text-vintage-dark" id="reviews-similar-count">—</span>
                <span class="text-[9px] text-vintage-olive block leading-tight mt-0.5">Similar Travelers</span>
              </div>
              <div class="bg-white p-2.5 rounded-lg vintage-border">
                <span class="text-base font-serif font-bold text-vintage-clay" id="reviews-avg-spice">— / 5</span>
                <span class="text-[9px] text-vintage-olive block leading-tight mt-0.5">Average Spice Felt</span>
              </div>
              <div class="bg-white p-2.5 rounded-lg vintage-border">
                <span class="text-base font-serif font-bold text-vintage-sage" id="reviews-would-again">—</span>
                <span class="text-[9px] text-vintage-olive block leading-tight mt-0.5">Would Eat Again</span>
              </div>
            </div>
            <p class="text-[10px] text-vintage-olive text-center" id="reviews-based-on"></p>

            <!-- Review list filter: Similar to Me / Same Country / All Travelers -->
            <div class="flex gap-1.5 p-1 bg-vintage-beige/50 rounded-xl vintage-border">
              <button onclick="setReviewsFilter('similar')" id="reviews-filter-similar" class="reviews-filter-btn flex-1 py-1.5 text-[11px] font-semibold rounded-lg transition bg-white text-vintage-dark shadow-sm">Similar to Me</button>
              <button onclick="setReviewsFilter('country')" id="reviews-filter-country" class="reviews-filter-btn flex-1 py-1.5 text-[11px] font-semibold rounded-lg transition text-vintage-olive hover:bg-white/50">Same Country</button>
              <button onclick="setReviewsFilter('all')" id="reviews-filter-all" class="reviews-filter-btn flex-1 py-1.5 text-[11px] font-semibold rounded-lg transition text-vintage-olive hover:bg-white/50">All Travelers</button>
            </div>

            <div class="space-y-3" id="reviews-list-container">
              <!-- Dynamic review cards injected here -->
            </div>

            <!-- Add Review Form -->
            <form onsubmit="submitReview(event)" class="bg-vintage-beige/30 p-4 rounded-xl space-y-3 vintage-border">
              <span class="text-xs font-bold text-vintage-olive uppercase" id="lbl-add-review">Add Your Review</span>
              <div class="grid grid-cols-2 gap-2">
                <select id="review-rating-input" class="text-xs p-2 rounded-lg bg-white vintage-border">
                  <option value="5">⭐ 5 - Excellent</option>
                  <option value="4">⭐ 4 - Good</option>
                  <option value="3">⭐ 3 - Average</option>
                  <option value="2">⭐ 2 - Bad</option>
                  <option value="1">⭐ 1 - Terrible</option>
                </select>
                <select id="review-spice-input" class="text-xs p-2 rounded-lg bg-white vintage-border">
                  <option value="1">🌶️ 1 - Not spicy</option>
                  <option value="2">🌶️ 2 - Mild</option>
                  <option value="3" selected>🌶️ 3 - Moderate</option>
                  <option value="4">🌶️ 4 - Very spicy</option>
                  <option value="5">🌶️ 5 - Extremely fiery</option>
                </select>
              </div>
              <textarea id="review-comment-input" required placeholder="Share your experience..." class="w-full h-16 text-xs p-2.5 rounded-lg bg-white vintage-border focus:outline-none focus:ring-1 focus:ring-vintage-clay"></textarea>
              <button type="submit" class="w-full py-2.5 bg-vintage-terracotta text-white rounded-lg text-xs font-bold hover:bg-vintage-dark transition" id="btn-submit-review">Submit Review</button>
            </form>
          </div>
        </section>

        <!-- ==================== TAB 2: MENU TRANSLATION (Camera / Upload) ==================== -->
        <section id="view-scanner" class="tab-content hidden p-4 space-y-4">
          <div class="flex justify-between items-center">
            <div>
              <h2 class="font-serif text-2xl font-bold text-vintage-dark" id="scan-title">Menu Translation</h2>
              <p class="text-xs text-vintage-olive" id="scan-subtitle">Snap or upload a menu to translate it and check ingredients</p>
            </div>
          </div>

          <!-- Camera Screen / Capture Interface -->
          <div class="relative aspect-video w-full bg-black rounded-2xl overflow-hidden border border-vintage-dark/20 vintage-shadow flex flex-col justify-between p-4">
            <!-- Simulated Camera Grid -->
            <div class="absolute inset-0 border-2 border-dashed border-white/20 m-4 pointer-events-none rounded-lg flex items-center justify-center">
              <div id="scan-laser" class="absolute left-0 right-0 h-0.5 bg-vintage-clay shadow-lg shadow-vintage-clay/80 top-0 transition-all duration-1000 hidden"></div>
            </div>
            
            <!-- Dynamic State views -->
            <div id="camera-blank" class="absolute inset-0 flex flex-col items-center justify-center text-center p-6 bg-vintage-dark">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-12 w-12 text-vintage-beige/40 mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" /><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z" /></svg>
              <p class="text-sm font-semibold text-vintage-beige" id="cam-blank-title">Add a Menu Photo</p>
