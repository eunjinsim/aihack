    // Clear the saved profile and return to the very first onboarding screen.
    // Useful for testers/developers who need to re-check the initial flow,
    // and for real users who want to fully reset their preferences.
    function resetToOnboarding() {
      const trans = translations[state.lang];
      const confirmMsg = trans.resetConfirm || 'Reset all saved settings and return to the start screen?';
      if (!window.confirm(confirmMsg)) return;

      // Reset in-memory state back to defaults
      state.dietary = 'none';
      state.nationality = '';
      state.selectedSpicy = 1;
      state.selectedAllergies.clear();
      state.customAllergies = [];
      state.hasScannedResult = false;
      state.isRealPhotoUpload = false;
      state.uploadedImageDataUrl = null;
      state.selectedLocation = null;
      state.currentLocIdx = 0;
      state.currentReviewFoodId = null;
      state.currentMapFilter = 'all';

      document.getElementById('custom-allergy-badges').innerHTML = '';
      const badge = document.getElementById('allergy-badge');
      if (badge) badge.classList.add('hidden');

      setLanguage('en');
      setSpicy(1);
      document.getElementById('diet-select').value = 'none';
      document.getElementById('modal-diet-select').value = 'none';
      document.getElementById('nationality-input').value = '';
      document.getElementById('modal-nationality-input').value = '';

      // Map should go back to showing only markers — no store/reviews left
      // over from before the reset — until a marker is tapped again.
      document.getElementById('location-detail-card').classList.add('hidden');
      document.getElementById('map-reviews-section').classList.add('hidden');
      setMapFilter('all');

      document.getElementById('main-app').classList.add('hidden');
      document.getElementById('landing-page').classList.remove('hidden');

      // Clear the saved profile last, so it isn't immediately re-persisted
      // by the setLanguage('en') call above (setLanguage saves the profile
      // whenever it runs while the main app is still visible).
      try {
        localStorage.removeItem(PROFILE_STORAGE_KEY);
      } catch (err) {
        console.error('Could not clear saved profile:', err);
      }
    }

    // Real-time Exchange rates via free Open-ER API representing live Naver data
    async function fetchLiveExchangeRates() {
      try {
        // Fetch exchange rates based on KRW (Korean Won) as anchor
        const response = await fetch('https://open.er-api.com/v6/latest/KRW');
        const data = await response.json();
        
        if (data && data.rates) {
          // Parse rates: open-er rates are quoted as unit of currency per 1 KRW.
          // e.g. "USD": 0.00074 => 1 USD = 1 / 0.00074 = 1351.35 KRW.
          state.currencyIndex.USD = Math.round(1 / data.rates.USD);
          state.currencyIndex.JPY = (1 / data.rates.JPY) / 10; // For 100 JPY
          state.currencyIndex.CNY = Math.round(1 / data.rates.CNY);
          state.currencyIndex.EUR = Math.round(1 / data.rates.EUR);
          state.currencyIndex.VND = (1 / data.rates.VND) * 1000; // For 1,000 VND

          // Store when this rate data is actually from (the API only updates
          // periodically — this shows the real date/time instead of implying
          // second-by-second "live" updates, which this data isn't).
          state.rateAsOfDate = data.time_last_update_utc ? new Date(data.time_last_update_utc) : new Date();
          updateRateAsOfDisplay();

          // Update Info indices block in UI
          document.getElementById('live-rate-indices').innerHTML = `
            <div>1 USD = ${state.currencyIndex.USD.toLocaleString()} KRW</div>
            <div>100 JPY = ${Math.round(state.currencyIndex.JPY * 100).toLocaleString()} KRW</div>
            <div>1 CNY = ${state.currencyIndex.CNY.toLocaleString()} KRW</div>
            <div>1 EUR = ${state.currencyIndex.EUR.toLocaleString()} KRW</div>
            <div>1,000 VND = ${Math.round(state.currencyIndex.VND).toLocaleString()} KRW</div>
          `;
          updateCurrentRateDisplay();
          calculateExchange(true);
        }
      } catch (e) {
        console.error("Live exchange rates fetch error, fallback active.", e);
      }
    }

    // Show the actual date/time the exchange rate data is from, in the
    // person's current app language. Replaces a misleading "LIVE" badge —
    // this data updates periodically (daily-ish), not second by second.
    function updateRateAsOfDisplay() {
      const badge = document.getElementById('live-rate-status');
      if (!badge) return;
      const trans = translations[state.lang];

      if (!state.rateAsOfDate) {
        badge.innerText = trans.liveSyncedText;
        return;
      }

      const localeMap = { en: 'en-US', ja: 'ja-JP', zh: 'zh-CN', vi: 'vi-VN', es: 'es-ES', ko: 'ko-KR' };
      const locale = localeMap[state.lang] || 'en-US';
      const formatted = new Intl.DateTimeFormat(locale, {
        month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit'
      }).format(state.rateAsOfDate);

      badge.innerText = `${trans.liveSyncedText}: ${formatted}`;
    }

    // Show a prominent "1 <currency> = X KRW" line for whichever currency
    // is currently selected, using the latest fetched (or fallback) rate.
    function updateCurrentRateDisplay() {
      const el = document.getElementById('current-rate-display');
      if (!el) return;
      const target = state.targetCurrency;
      let unit = 1;
      let rate = state.currencyIndex[target];
      if (target === 'JPY') {
        unit = 100;
        rate = Math.round(state.currencyIndex.JPY * 100);
      } else if (target === 'VND') {
        unit = 1000;
        rate = Math.round(state.currencyIndex.VND);
      } else {
        rate = Math.round(rate);
      }
      el.innerText = `${unit.toLocaleString()} ${target} = ${rate.toLocaleString()} KRW`;
    }

    // Currency Switcher
    function setCurrency(target) {
      state.targetCurrency = target;

      // Update selector buttons styling
      document.querySelectorAll('.cur-selector').forEach(btn => {
        btn.classList.remove('bg-vintage-terracotta', 'text-white', 'border-vintage-terracotta');
        btn.classList.add('bg-white', 'text-vintage-dark');
      });

      const activeBtn = document.getElementById(`cur-btn-${target}`);
      if (activeBtn) {
        activeBtn.classList.remove('bg-white', 'text-vintage-dark');
        activeBtn.classList.add('bg-vintage-terracotta', 'text-white', 'border-vintage-terracotta');
      }

      // Update symbol representation labels
      const currencySymbols = { USD: 'USD ($)', JPY: 'JPY (¥)', CNY: 'CNY (¥)', EUR: 'EUR (€)', VND: 'VND (₫)' };
      document.getElementById('foreign-symbol').innerText = currencySymbols[target];

      // Update the prominent current-rate line for the newly selected currency
      updateCurrentRateDisplay();

      // Re-trigger math calculation
      calculateExchange(true);
    }

    // Perform dual path conversion
    function calculateExchange(isForeignInput) {
      const foreignInput = document.getElementById('foreign-input');
      const krwInput = document.getElementById('krw-input');
      const rate = state.currencyIndex[state.targetCurrency];

      if (isForeignInput) {
        const val = parseFloat(foreignInput.value) || 0;
        let result = 0;
        if (state.targetCurrency === 'JPY') {
          result = Math.round(val * (rate));
        } else if (state.targetCurrency === 'VND') {
          result = Math.round((val / 1000) * rate);
        } else {
          result = Math.round(val * rate);
        }
        krwInput.value = result;
      } else {
        const val = parseFloat(krwInput.value) || 0;
        let result = 0;
        if (state.targetCurrency === 'JPY') {
          result = Math.round((val / (rate)) * 100) / 100;
        } else if (state.targetCurrency === 'VND') {
          result = Math.round(((val * 1000) / rate) * 100) / 100;
        } else {
          result = Math.round((val / rate) * 100) / 100;
        }
        foreignInput.value = result;
      }
    }

    // User Profile settings modal toggle mechanics
    function openProfileModal() {
      document.getElementById('modal-diet-select').value = state.dietary;
      document.getElementById('modal-nationality-input').value = state.nationality;
      setSpicy(state.selectedSpicy);

      const modal = document.getElementById('profile-modal');
      const modalBody = document.getElementById('profile-modal-body');
      
      modal.classList.remove('hidden');
      setTimeout(() => {
        modalBody.classList.remove('translate-y-full');
      }, 50);
    }

    function closeProfileModal() {
      const modal = document.getElementById('profile-modal');
      const modalBody = document.getElementById('profile-modal-body');

      modalBody.classList.add('translate-y-full');
      setTimeout(() => {
        modal.classList.add('hidden');
      }, 300);

      saveProfileToStorage();
      showToast(translations[state.lang].toastProfileSave);
    }

    // ==========================================
    // TRAVELER REVIEWS MODAL LOGIC
    // ==========================================

    function renderReviewsList() {
      const foodId = state.currentReviewFoodId;
      const container = document.getElementById('reviews-list-container');
      container.innerHTML = '';

      const allReviews = (foodId && REVIEWS_DATABASE[foodId]) ? REVIEWS_DATABASE[foodId] : [];

      if (allReviews.length === 0) {
        container.innerHTML = `<p class="text-xs text-vintage-olive italic text-center py-4">No reviews yet. Be the first to share your experience!</p>`;
        document.getElementById('reviews-country-strong-pct').innerText = '—';
        document.getElementById('reviews-similar-count').innerText = '—';
        document.getElementById('reviews-avg-spice').innerText = '—';
        document.getElementById('reviews-would-again').innerText = '—';
        document.getElementById('reviews-based-on').innerText = '';
        return;
      }

      const userCountry = getUserCountry();
      const userSpiceTolerance = state.selectedSpicy + 1;
      const userDietary = state.dietary;

      // Stat: among reviewers from the SAME country, % who rated this dish
      // "Strong" or higher (spiceFelt >= 4) — e.g. "82% of American
      // travelers rated this dish Strong or higher".
      const sameCountryReviews = allReviews.filter(r => r.country === userCountry);
      const strongPct = sameCountryReviews.length > 0
        ? Math.round((sameCountryReviews.filter(r => r.spiceFelt >= 4).length / sameCountryReviews.length) * 100)
        : null;

      // Cascading "similar traveler" pool drives count / avg spice / would-again
      const { reviews: similarReviews, tier } = findSimilarTravelerReviews(allReviews, userCountry, userSpiceTolerance, userDietary);
      const avgSpice = (similarReviews.reduce((sum, r) => sum + r.spiceFelt, 0) / similarReviews.length).toFixed(1);
      const againPct = Math.round((similarReviews.filter(r => r.wouldAgain).length / similarReviews.length) * 100);

      document.getElementById('reviews-country-strong-pct').innerText = strongPct !== null ? `${strongPct}%` : '—';
      document.getElementById('reviews-country-strong-label').innerText = `of ${userCountry} travelers rated Strong+`;
      document.getElementById('reviews-similar-count').innerText = `${similarReviews.length}`;
      document.getElementById('reviews-avg-spice').innerText = `${avgSpice} / 5`;
      document.getElementById('reviews-would-again').innerText = `${againPct}%`;

      const dietaryLabelMap = { none: 'No dietary restriction', vegan: 'Vegan', halal: 'Halal', vegetarian: 'Vegetarian' };
      const tierBasisMap = {
        'country+spice+dietary': `${userCountry} · Spice Level ${userSpiceTolerance} · ${dietaryLabelMap[userDietary] || userDietary}`,
        'country+spice': `${userCountry} · Spice Level ${userSpiceTolerance}`,
        'country': `${userCountry}`,
        'all': 'All travelers'
      };
      document.getElementById('reviews-based-on').innerText = `Based on: ${tierBasisMap[tier]}`;

      // Which reviews are actually listed depends on the separate Similar /
      // Same Country / All toggle — independent from the stat tiles above.
      let listedReviews;
      if (state.reviewsFilterMode === 'country') {
        listedReviews = sameCountryReviews.length > 0 ? sameCountryReviews : allReviews;
      } else if (state.reviewsFilterMode === 'all') {
        listedReviews = allReviews;
      } else {
        listedReviews = similarReviews;
      }

      if (listedReviews.length === 0) {
        container.innerHTML = `<p class="text-xs text-vintage-olive italic text-center py-4">No reviews match this filter yet.</p>`;
        return;
      }

      listedReviews.slice().reverse().forEach(review => {
        const card = document.createElement('div');
        card.className = "bg-white p-3.5 rounded-xl vintage-border space-y-1.5";
        const stars = '⭐'.repeat(review.rating) + '<span class="opacity-20">' + '⭐'.repeat(5 - review.rating) + '</span>';
        const dietaryTag = review.dietary && review.dietary !== 'none' ? ` • ${review.dietary}` : '';
        const tagsHtml = (review.tasteTags || []).map(tag => `<span class="text-[9px] px-1.5 py-0.5 rounded-full bg-vintage-beige text-vintage-olive">${tag}</span>`).join('');
        card.innerHTML = `
          <div class="flex justify-between items-start">
            <div>
              <span class="font-bold text-vintage-dark text-sm block">${review.user}</span>
              <span class="text-[10px] text-vintage-olive">${review.country} • Spice tolerance Lvl ${review.spiceTolerance}${dietaryTag}</span>
            </div>
            <span class="text-xs">${stars}</span>
          </div>
          <p class="text-xs text-vintage-dark leading-relaxed">"${review.text}"</p>
          ${tagsHtml ? `<div class="flex flex-wrap gap-1">${tagsHtml}</div>` : ''}
          <div class="flex items-center justify-between pt-1">
            <span class="text-[10px] font-mono text-vintage-clay">🌶️ Felt: Lvl ${review.spiceFelt}</span>
            <span class="text-[10px] font-bold px-2 py-0.5 rounded ${review.wouldAgain ? 'bg-emerald-50 text-emerald-700' : 'bg-red-50 text-red-700'}">${review.wouldAgain ? 'Would eat again' : 'Would avoid'}</span>
          </div>
        `;
        container.appendChild(card);
      });
    }

    // Switch which reviews are listed (stat tiles above stay on the same
    // cascading "similar traveler" logic regardless of this toggle).
    function setReviewsFilter(mode) {
      state.reviewsFilterMode = mode;
      document.querySelectorAll('.reviews-filter-btn').forEach(btn => {
        btn.classList.remove('bg-white', 'text-vintage-dark', 'shadow-sm');
        btn.classList.add('text-vintage-olive');
      });
      const activeBtn = document.getElementById(`reviews-filter-${mode}`);
      if (activeBtn) {
        activeBtn.classList.add('bg-white', 'text-vintage-dark', 'shadow-sm');
        activeBtn.classList.remove('text-vintage-olive');
      }
      renderReviewsList();
    }

    // Submit a new traveler review (in-memory only, resets on reload)
    function submitReview(event) {
      event.preventDefault();
      const foodId = state.currentReviewFoodId;
      if (!foodId) return;

      const rating = parseInt(document.getElementById('review-rating-input').value, 10);
      const spiceFelt = parseInt(document.getElementById('review-spice-input').value, 10);
      const text = document.getElementById('review-comment-input').value.trim();
      if (!text) return;

      if (!REVIEWS_DATABASE[foodId]) {
        REVIEWS_DATABASE[foodId] = [];
      }

      REVIEWS_DATABASE[foodId].push({
        user: "You",
        country: getUserCountry(),
        spiceTolerance: state.selectedSpicy + 1,
        dietary: state.dietary,
        tasteTags: [],
        rating: rating,
        spiceFelt: spiceFelt,
        text: text,
        wouldAgain: rating >= 3
      });

      document.getElementById('review-comment-input').value = '';
      renderReviewsList();
      showToast("Thanks for sharing your review!");
    }
  </script>
