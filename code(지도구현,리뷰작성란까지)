        bannerIcon.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z" /></svg>`;
      } else if (safetyState === 'orange') {
        banner.className = "p-3 rounded-xl bg-amber-50 text-amber-900 border border-amber-200";
        bannerTitle.innerText = trans.warnTitle;
        bannerDesc.innerText = isCrossContact ? `${trans.crossDesc} (${matchedDangers.join(', ').toUpperCase()})` : trans.warnDesc;
        bannerIcon.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-amber-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>`;
      } else {
        banner.className = "p-3 rounded-xl bg-red-50 text-red-900 border border-red-200";
        bannerTitle.innerText = trans.dangerTitle;
        bannerDesc.innerText = `${trans.dangerDesc} (Matched: ${matchedDangers.join(', ').toUpperCase()})`;
        bannerIcon.innerHTML = `<svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" /></svg>`;
      }

      // Update spec sheet
      document.getElementById('spec-val-name').innerText = matchObj.name;
      document.getElementById('spec-val-ingredients').innerText = matchObj.ingredients;
      document.getElementById('spec-val-allergens').innerText = (matchObj.allergens || []).length > 0 ? matchObj.allergens.join(', ') : 'None';
      
      const spicyTextMap = ['Mild (Lvl 1)', 'Normal (Lvl 2)', 'Hot (Lvl 3) 🔥', 'Extreme (Lvl 4) 🌶️'];
      document.getElementById('spec-val-spicy').innerText = spicyTextMap[matchObj.spicy] || spicyTextMap[0];

      // Dietary Flags badges
      const flagsContainer = document.getElementById('spec-dietary-flags');
      flagsContainer.innerHTML = '';
      (matchObj.dietaryFlags || []).forEach(flag => {
        const badge = document.createElement('span');
        badge.className = "text-[10px] font-bold px-2 py-0.5 rounded-full bg-vintage-dark/5 text-vintage-olive border border-vintage-dark/10";
        badge.innerText = flag;
        flagsContainer.appendChild(badge);
      });

      // How to Eat (Korean Way) steps
      const stepsContainer = document.getElementById('eating-method-list');
      stepsContainer.innerHTML = '';
      (matchObj.eatingMethod || []).forEach((step, idx) => {
        const row = document.createElement('div');
        row.className = "flex gap-2 items-start";
        row.innerHTML = `
          <span class="w-5 h-5 shrink-0 rounded-full bg-vintage-clay/20 text-vintage-terracotta text-[10px] font-bold flex items-center justify-center mt-0.5">${idx + 1}</span>
          <p class="text-xs text-vintage-dark leading-relaxed">${step}</p>
        `;
        stepsContainer.appendChild(row);
      });

      // Cultural note box
      const cultureBox = document.getElementById('cultural-note-box');
      const cultureText = document.getElementById('cultural-note-text');
      if (matchObj.culturalNote) {
        cultureText.innerText = matchObj.culturalNote;
        cultureBox.classList.remove('hidden');
      } else {
        cultureBox.classList.add('hidden');
      }

      // Track this dish's foodId for potential review lookups elsewhere (e.g. Map tab)
      state.currentReviewFoodId = matchObj.foodId || null;
      state.lastScannedDishNamesKo = [matchObj.nameKo || extractKoreanName(matchObj.name)];

      // Ensure the single-dish view is shown (multi-dish AAI view has its own toggle)
      document.getElementById('single-dish-details').classList.remove('hidden');
      document.getElementById('multi-dish-list').classList.add('hidden');

      // Expose Pane
      document.getElementById('scan-result-pane').classList.remove('hidden');
      showToast(translations[state.lang].toastScanDone);
    }

    // Reset simulator lens to capture state
    function resetScanner() {
      document.getElementById('scanned-image-preview').classList.add('hidden');
      document.getElementById('camera-blank').classList.remove('hidden');
      document.getElementById('btn-trigger-scan').disabled = true;
      document.getElementById('scan-result-pane').classList.add('hidden');
      document.getElementById('scan-loc-indicator').innerText = 'Jeonpo: Offline Mode';
